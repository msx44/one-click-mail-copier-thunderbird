{
  "manifest_version": 3,
  "name": "One-Click Mail Copier",
  "version": "2.1",
  "description": "メールの情報を好みのフォーマットでクリップボードに一発コピーします。",
  "permissions": [
    "messagesRead",
    "clipboardWrite",
    "storage"
  ],
  "icons": {
    "128": "icon.png"
  },
  "message_display_action": {
    "default_popup": "popup.html",
    "default_title": "📋カスタマイズコピー",
    "default_icon": "icon.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "one-click-mail-copier@msx44.extensions",
      "strict_min_version": "128.0"
    }
  }
}